FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit>=1.30.0 \
    httpx>=0.27.0 \
    pandas>=2.0.0 \
    plotly>=5.18.0 \
    psycopg2-binary>=2.9.0

COPY app_foonalert_demo.py /app/app_foonalert_demo.py
COPY demo_data /app/demo_data

EXPOSE 8502

CMD ["streamlit", "run", "app_foonalert_demo.py", "--server.port=8502", "--server.address=0.0.0.0", "--server.headless=true"]
